---
// 1. הוראה מפורשת לאסטרו: אל תשמור את הדף בזיכרון, תמיד תבדוק מול סאניטי
export const prerender = false;

import { sanity } from '../../lib/sanity'
import PortableText from '../../components/PortableText.astro'

const { slug } = Astro.params;

// 2. הוספת פרמטר זמן לשאילתה כדי להכריח את סאניטי לדלג על ה-CDN
const pageData = await sanity.fetch(`
  *[_type == "landingPage" && slug.current == $slug][0]{
    title,
    subtitle,
    "imageUrl": mainImage.asset->url,
    content,
    bullets,
    cta,
    trustText,
    newsletterConsent,
    newsletterConsentText,
    "pdfUrl": leadMagnet.asset->url
  }
`, { slug }, { cache: 'no-store' });

if (!pageData) {
  return new Response('Not found', { status: 404 });
}

const formSubmitEmail = "yossi1974@outlook.co.il"; 
const nextUrl = `https://heartcompass.vercel.app/guide/thanks?guide=${slug}`;
---

<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageData.title} | מצפן הלב</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Assistant', sans-serif; }
    /* עיצוב כפוי לצ'קבוקס למקרה ש-Tailwind Forms מעלים אותו */
    input[type="checkbox"] {
      appearance: checkbox !important;
      -webkit-appearance: checkbox !important;
      display: inline-block !important;
      width: 20px !important;
      height: 20px !important;
      opacity: 1 !important;
      visibility: visible !important;
    }
  </style>
</head>
<body class="bg-white text-slate-900 leading-relaxed overflow-x-hidden">
  <main class="max-w-6xl mx-auto px-4 py-12 md:py-24">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      
      <div class="space-y-8 order-2 md:order-1 text-right">
        <h1 class="text-4xl md:text-6xl font-bold text-slate-900">{pageData.title}</h1>
        <p class="text-xl text-slate-600">{pageData.subtitle}</p>
        <div class="prose prose-lg text-slate-700">
          <PortableText value={pageData.content} />
        </div>
      </div>

      <div class="order-1 md:order-2 space-y-8">
        <section class="bg-slate-50 p-6 md:p-8 rounded-2xl border border-slate-100">
          <form action={`https://formsubmit.co/${formSubmitEmail}`} method="POST" class="space-y-4">
            <input type="hidden" name="_next" value={nextUrl}>
            <input type="text" name="name" required placeholder="שם מלא" class="w-full px-4 py-4 rounded-xl border border-slate-200 text-right">
            <input type="email" name="email" required placeholder="כתובת מייל" class="w-full px-4 py-4 rounded-xl border border-slate-200 text-right">

            {/* שורת הסכמה קבועה ללא תנאים כדי לוודא נראות */}
            <div class="flex items-start gap-3 py-4 px-2 bg-white rounded-lg border border-slate-200 shadow-sm">
              <input 
                type="checkbox" 
                name="הסכמה_לדיוור" 
                id="consent" 
                checked
                required
              >
              <label for="consent" class="text-sm text-slate-700 cursor-pointer pr-1">
                {pageData.newsletterConsentText || 'אני מאשר לקבל תובנות וכלים שיעזרו לי להבין את השומר הפנימי שלי'}
              </label>
            </div>

            <button type="submit" class="w-full bg-slate-900 text-white font-bold text-xl py-5 rounded-xl shadow-lg cursor-pointer">
              {pageData.cta}
            </button>
          </form>
        </section>
      </div>
    </div>
  </main>
</body>
</html>
