---
import { sanity } from '../../lib/sanity'
import PortableText from '../../components/PortableText.astro'

const { slug } = Astro.params;

const pageData = await sanity.fetch(`
  *[_type == "landingPage" && slug.current == $slug][0]{
    title,
    subtitle,
    "imageUrl": mainImage.asset->url,
    content,
    bullets,
    cta,
    trustText,
    "pdfUrl": leadMagnet.asset->url
  }
`, { slug });

if (!pageData) {
  return new Response('Not found', { status: 404 });
}

const formSubmitEmail = "yossi1974@outlook.co.il"; 
const nextUrl = "https://heartcompass.vercel.app/guide/thanks"; 
---

<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageData.title} | מצפן הלב</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;700&display=swap" rel="stylesheet">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900 font-['Assistant',sans-serif] antialiased">

  <main class="min-h-screen flex items-center justify-center p-4 md:p-8">
    <div class="max-w-6xl w-full bg-white rounded-3xl shadow-xl overflow-hidden flex flex-col lg:flex-row border border-slate-100 text-right">
      
      <div class="w-full lg:w-1/2 p-8 md:p-12 lg:p-16 flex flex-col justify-center order-2 lg:order-1">
        
        <header class="mb-10">
          <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6 leading-tight">
            {pageData.title}
          </h1>
          {pageData.subtitle && (
            <p class="text-xl md:text-2xl text-slate-600 leading-relaxed">
              {pageData.subtitle}
            </p>
          )}
        </header>

        {pageData.content && (
          <div class="prose prose-lg text-slate-700 mb-8 leading-relaxed">
            <PortableText value={pageData.content} />
          </div>
        )}

        {pageData.bullets && pageData.bullets.length > 0 && (
          <section class="mb-10">
            <ul class="space-y-4">
              {pageData.bullets.map((bullet) => (
                <li class="flex items-start text-lg text-slate-800">
                  <span class="text-slate-400 ml-4 mt-1">—</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        <section class="bg-slate-50 p-6 md:p-8 rounded-2xl border border-slate-100">
          <form action={`https://formsubmit.co/${formSubmitEmail}`} method="POST" class="space-y-4">
            <input type="hidden" name="_next" value={nextUrl}>
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_subject" value={`בקשה למדריך: ${pageData.title}`}>
            
            <input type="text" name="name" required placeholder="שם מלא" 
                   class="w-full px-4 py-4 rounded-xl bg-white border border-slate-200 focus:border-slate-400 outline-none transition-all text-lg text-right">
            
            <input type="email" name="email" required placeholder="כתובת מייל" 
                   class="w-full px-4 py-4 rounded-xl bg-white border border-slate-200 focus:border-slate-400 outline-none transition-all text-lg text-right">

            <button type="submit" 
                    class="w-full bg-slate-900 hover:bg-black text-white font-bold text-xl py-5 rounded-xl transition-all mt-4 cursor-pointer shadow-lg">
              {pageData.cta}
            </button>
          </form>
          
          <p class="text-sm text-slate-400 mt-6 text-center italic">
            {pageData.trustText}
          </p>
        </section>

      </div>

      {pageData.imageUrl && (
        <div class="w-full lg:w-1/2 bg-slate-100 order-1 lg:order-2 relative h-64 lg:h-auto">
          <img 
            src={pageData.imageUrl} 
            alt={pageData.title} 
            class="absolute inset-0 w-full h-full object-cover"
          />
        </div>
      )}

    </div>
  </main>

</body>
</html>