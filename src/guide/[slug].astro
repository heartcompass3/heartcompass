---
import { sanity } from '../../lib/sanity'
import PortableText from '../../components/PortableText.astro'

const { slug } = Astro.params;

const pageData = await sanity.fetch(`
  *[_type == "landingPage" && slug.current == $slug][0]{
    title,
    subtitle,
    "imageUrl": mainImage.asset->url,
    content,
    bullets,
    cta,
    trustText,
    newsletterConsent,
    newsletterConsentText,
    "pdfUrl": leadMagnet.asset->url
  }
`, { slug });

if (!pageData) {
  return new Response('Not found', { status: 404 });
}

const formSubmitEmail = "yossi1974@outlook.co.il"; 
const nextUrl = `https://heartcompass.vercel.app/guide/thanks?guide=${slug}`; 
---

<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageData.title} | מצפן הלב</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Assistant', sans-serif; }
  </style>
</head>
<body class="bg-white text-slate-900 leading-relaxed overflow-x-hidden">
  
  <main class="max-w-6xl mx-auto px-4 py-12 md:py-24">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      
      {/* צד ימין: תוכן */}
      <div class="space-y-8 order-2 md:order-1 text-right">
        <div class="inline-block px-4 py-1 bg-slate-100 text-slate-600 rounded-full text-sm font-semibold mb-4">
          מדריך חינמי בלעדי
        </div>
        <h1 class="text-4xl md:text-6xl font-bold leading-tight text-slate-900">
          {pageData.title}
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 leading-relaxed">
          {pageData.subtitle}
        </p>

        {pageData.bullets && pageData.bullets.length > 0 && (
          <ul class="space-y-4">
            {pageData.bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-lg">
                <span class="text-slate-900 mt-1">✓</span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        )}

        <div class="prose prose-lg max-w-none text-slate-700">
          <PortableText value={pageData.content} />
        </div>
      </div>

      {/* צד שמאל: טופס ותמונה */}
      <div class="order-1 md:order-2 space-y-8">
        {pageData.imageUrl && (
          <div class="rounded-3xl overflow-hidden shadow-2xl transform rotate-2">
            <img src={pageData.imageUrl} alt={pageData.title} class="w-full h-auto" />
          </div>
        )}

        <section id="form" class="bg-slate-50 p-6 md:p-8 rounded-2xl border border-slate-100">
          <form action={`https://formsubmit.co/${formSubmitEmail}`} method="POST" class="space-y-4">
            <input type="hidden" name="_next" value={nextUrl}>
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_subject" value={`בקשה למדריך: ${pageData.title}`}>

            <input type="text" name="name" required placeholder="שם מלא" class="w-full px-4 py-4 rounded-xl bg-white border border-slate-200 focus:border-slate-400 outline-none transition-all text-lg text-right">
            <input type="email" name="email" required placeholder="כתובת מייל" class="w-full px-4 py-4 rounded-xl bg-white border border-slate-200 focus:border-slate-400 outline-none transition-all text-lg text-right">

            {/* שורת ההסכמה החדשה */}
            {pageData.newsletterConsent && (
              <div class="flex items-start gap-3 py-2 px-1 text-right">
                <input 
                  type="checkbox" 
                  name="הסכמה_לדיוור" 
                  id="consent" 
                  checked 
                  class="mt-1.5 w-5 h-5 rounded border-slate-300 text-slate-900 focus:ring-slate-500"
                >
                <label for="consent" class="text-sm text-slate-600 leading-snug cursor-pointer">
                  {pageData.newsletterConsentText}
                </label>
              </div>
            )}

            <button type="submit" class="w-full bg-slate-900 hover:bg-black text-white font-bold text-xl py-5 rounded-xl transition-all mt-4 cursor-pointer shadow-lg">
              {pageData.cta}
            </button>
          </form>
          <p class="text-sm text-slate-400 mt-6 text-center italic">{pageData.trustText}</p>
        </section>
      </div>
    </div>
  </main>

  <footer class="py-12 border-t border-slate-100 text-center text-slate-400">
    <p>© {new Date().getFullYear()} מצפן הלב - יוסי מדלסי</p>
  </footer>
</body>
</html>
