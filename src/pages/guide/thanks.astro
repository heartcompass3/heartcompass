---
import { sanity } from '../../lib/sanity'

// משיכת ה-PDF מסאניטי עם ערך ברירת מחדל כדי למנוע היעלמות הכפתור [cite: 14]
const guideData = await sanity.fetch(`*[_type == "landingPage" && slug.current == "overthinking-releese-guide"][0]{ "pdfUrl": leadMagnet.asset->url }`);
const pdfUrl = guideData?.pdfUrl || "#"; 
---

<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>תודה - המדריך שלך מוכן</title>
  <script is:inline src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900 font-sans antialiased">
  <main class="min-h-screen flex items-center justify-center p-6 text-center">
    <div class="max-w-xl w-full bg-white p-12 rounded-3xl shadow-xl border border-slate-100">
      <h1 class="text-3xl font-bold mb-6 italic">ההרשמה הסתיימה בהצלחה</h1>
      <p class="text-xl text-slate-600 mb-10 leading-relaxed">המדריך מחכה לך בלחיצה על הכפתור למטה.</p>

      <a href={pdfUrl} target="_blank" download
         class="inline-block w-full bg-slate-900 hover:bg-black text-white font-bold text-xl py-5 rounded-xl transition-all shadow-lg">
        להורדת המדריך עכשיו
      </a>
      
      <a href="/" class="block mt-8 text-slate-400 hover:text-slate-600">חזרה לאתר הבית</a>
    </div>
  </main>
</body>
</html>
