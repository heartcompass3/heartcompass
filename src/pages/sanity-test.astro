---
import { sanity } from '../lib/sanity'

const pages = await sanity.fetch(`*[_type == "page"]{ title, slug }`)
---

<html lang="he">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Sanity test</title>
  </head>
  <body>
    <h1>Sanity test</h1>
    <ul>
      {pages.map((p) => (
        <li>{p.title} – {p.slug?.current}</li>
      ))}
    </ul>
  </body>
</html>
