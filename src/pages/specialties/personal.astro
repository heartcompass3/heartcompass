---
import BaseLayout from '../../layouts/BaseLayout.astro'
import site from '../../content/pages/site.json'
import { sanity } from '../../lib/sanity'
import { buildBreadcrumbListSchema } from '../../lib/breadcrumbs'

const SLUG_FULL = 'specialties/personal'
const SLUG_SHORT = 'personal'

const page = await sanity.fetch(
  `*[_type=="page" && slug.current in [$full, $short]][0]{
    title,
    excerpt,
    specialty{
      intro,
      faqTitle,
      faq[]{
        question, answer
      },
      closing
    },
    seo{
      title,
      description,
      canonical,
      noindex,
      ogImage{
        asset->{url}
      }
    }
  }`,
  { full: SLUG_FULL, short: SLUG_SHORT }
)

const fallback = {
  title: 'התפתחות אישית בשיטת מ.ס.ע',
  gold: 'כשהרעש הפנימי מנהל את הבחירות שלך. שחרור מדפוסים אוטומטיים, חוסר ביטחון וקשרים רעילים.',
  intro: 'התפתחות אישית היא לא פרויקט של "תיקון עצמי", אלא מסע של גילוי המנגנונים שמנהלים אותך מבלי ששמת לב. תהליך מ.ס.ע מפרק את הלופים הרגשיים בדיוק בנקודות הכואבות: איפה שאיבדת את הביטחון ואיפה שהפחד מנהל את הבחירות שלך.',
  faqTitle: 'שאלות ותשובות',
  closing: 'ברגע שמפרקים את התגובות האוטומטיות, הזוגיות הופכת לנכונה יותר, הביטחון נובע מבפנים, והבחירות שלך הופכות להיות שלך באמת.'
}

const title = page?.seo?.title || page?.title || `${fallback.title} | ${site.brand}`
const description = page?.seo?.description || page?.excerpt || fallback.gold
const canonical = page?.seo?.canonical || new URL(Astro.url.pathname, site.siteUrl).toString()
const noindex = page?.seo?.noindex || false
const ogImage = page?.seo?.ogImage?.asset?.url || undefined

const h1 = page?.title || fallback.title
const gold = page?.excerpt || fallback.gold
const intro = page?.specialty?.intro || fallback.intro
const faqTitle = page?.specialty?.faqTitle || fallback.faqTitle
const faqs = page?.specialty?.faq || []
const closing = page?.specialty?.closing || fallback.closing

const breadcrumbSchema = buildBreadcrumbListSchema({
  siteUrl: site.siteUrl,
  brandName: site.brand,
  crumbs: [
    { name: 'תחומי התמחות', item: `${site.siteUrl}/specialties` },
    { name: h1, item: canonical },
  ],
})

const schemaArray = [breadcrumbSchema]
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noindex={noindex}
  ogImage={ogImage}
  schema={schemaArray}
>
  <section class="animate-fade-in py-24 bg-background min-h-screen">
    <div class="max-w-4xl mx-auto px-6">
      <header class="mb-10 text-center">
        {h1 && (
          <h1 class="text-5xl md:text-6xl font-black text-primary font-display mb-6">
            {h1}
          </h1>
        )}

        {gold && (
          <p class="text-xl text-accent font-body font-bold max-w-3xl mx-auto">
            {gold}
          </p>
        )}

        {intro && (
          <p class="mt-8 text-lg text-primary/70 font-body leading-relaxed max-w-3xl mx-auto">
            {intro}
          </p>
        )}
      </header>

      {faqs.length > 0 && (
        <div class="bg-white p-10 md:p-16 rounded-[3rem] shadow-elegant border border-white mb-16">
          <h2 class="text-2xl font-black text-primary font-display mb-10 text-center">
            {faqTitle}
          </h2>

          <div class="space-y-4">
            {faqs.map((item) => (
              <details class="group border border-primary/10 rounded-2xl p-6 bg-background cursor-pointer">
                <summary class="flex justify-between items-center list-none font-black text-lg text-primary">
                  {item.question}
                  <span class="text-2xl text-accent transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 text-primary/80 leading-relaxed">{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      )}

      {closing && (
        <div class="mt-10 mb-16 bg-white p-8 rounded-2xl shadow-sm border border-accent/10">
          <div class="text-primary/85 font-body leading-relaxed text-center text-lg font-bold">
            {closing}
          </div>
        </div>
      )}

      <div class="text-center pb-16">
        <a
          href={site.primaryCtaHref}
          class="inline-flex items-center gap-3 px-8 py-4 rounded-2xl gradient-gold text-white font-bold shadow-gold"
        >
          {site.primaryCtaLabel} <span aria-hidden="true">←</span>
        </a>
      </div>

    </div>
  </section>
</BaseLayout>
